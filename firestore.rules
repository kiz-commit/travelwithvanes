rules_version = '2';

// Copy into Firebase Console → Firestore Database → Rules → Publish.
// Merge with any existing rules (for example if you add custom claims for admin).
// Tighten `read` later (e.g. only `published` docs) if you need to hide drafts.

service cloud.firestore {
  match /databases/{database}/documents {
    match /itineraries/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /products/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /ugc_posts/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /site_settings/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
