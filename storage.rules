rules_version = '2';

// Copy into Firebase Console → Storage → Rules → Publish
// The path type in rules does not support string methods like .startsWith() on
// all match variables; use explicit path prefixes (see Firebase docs).
// Public read; writes require signed-in Firebase Auth (admin).

service firebase.storage {
  match /b/{bucket}/o {
    match /itineraries/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ugc/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
